  "testimonials": {
    "eyebrow": "Don't just take our word for it",
    "heading": "What our local fans are saying",
    "list": [
      {
        "quote": "The Local Jam is as close as you can get to live hit music in the Rhinebeck/ Red Hook area. They had a record setting crowd that sang along throughout and kept singing long after the show had ended! How lucky we are to have such fabulous musicians and vocalists as neighbors!!",
        "name": "Concert Committee Member",
        "detail": "Roger Phillips Concert Series"
      },
      {
        "quote": "A big shout out to The Local Jam for helping make our Annual Fundraiser a success! The music was outstanding and helped boost attendance and participation in this important event",
        "name": "Local Non-Profit",
        "detail": ""
      },
      {
        "quote": "Thank you to The Local Jam for helping to make my wife's birthday party a blast! The music entertainment was so enjoyable, that the guests asked you to play an extra hour, as we partied late into the night!",
        "name": "Private Party Client",
        "detail": ""
      },
      {
        "quote": "The Local Jam band is our \"house favorite\" for our restaurant. Your song selections are enjoyed by customers of all ages, the harmonies are outstanding, and our biggest crowds are when The Local Jam is scheduled.",
